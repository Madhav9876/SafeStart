# Browser-exposed values. Vite embeds VITE_* variables into the frontend bundle.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_AUTH_PROXY=

# Server-only values. Add these in Vercel Project Settings, never in public code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional database wake/restore integration.
FULLSTACK_PROJECT_REF=
FULLSTACK_RESTORE_API_URL=
